# Scriptura Plugin SDK CMake Configuration
# Provides:
#   ScripturaPluginSDK::PluginInterface - plugin interface headers
#   ScripturaPluginSDK::PluginSystem - full plugin system (for integration builds)

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Qt6 REQUIRED COMPONENTS Core Widgets)

if(NOT TARGET ScripturaPluginSDK::PluginInterface)
    add_library(ScripturaPluginSDK::PluginInterface INTERFACE IMPORTED)
    set_target_properties(ScripturaPluginSDK::PluginInterface PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@/scriptura"
    )
endif()

if(NOT TARGET ScripturaPluginSDK::PluginSystem)
    add_library(ScripturaPluginSDK::PluginSystem INTERFACE IMPORTED)
    set_target_properties(ScripturaPluginSDK::PluginSystem PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@"
        INTERFACE_LINK_LIBRARIES Qt6::Core Qt6::Widgets
    )
endif()

check_required_components(ScripturaPluginSDK)
