{
    "id": "com.scriptura.git",
    "name": "Git Integration",
    "version": "1.0.0",
    "author": "Scriptura Team",
    "description": "Git version control integration with commit, push, and status viewing",
    "mainClass": "GitPlugin",
    "library": "gitplugin.so",
    "category": "vcs",
    "features": ["VCSIntegration"],
    "tags": ["git", "version-control", "commit", "push"],
    "dependencies": [],
    "optionalDependencies": [],
    "settings": {
        "autoFetch": {
            "type": "bool",
            "default": false,
            "description": "Automatically fetch from remote"
        },
        "commitOnSave": {
            "type": "bool",
            "default": false,
            "description": "Automatically commit on file save"
        }
    },
    "permissions": [
        "process.execution"
    ]
}
